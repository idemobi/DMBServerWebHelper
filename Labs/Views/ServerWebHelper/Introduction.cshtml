    @using (Html.RowBuilder().AsPillarGrid().Begin())
    {
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsPillarCard().Begin())
            {
                @using (Html.BlockBuilder().AsTopMargin().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-globe text-primary me-1").Begin()) { }
                    @Html.TitleBuilder().SetTitle("Request Helpers", TitleLevel.Five).AsCompact().Render()
                }
                @using (Html.PB_P().AsSmallMuted().Begin())
                {
                    @:Web-oriented utilities simplify common request, culture and language concerns.
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsPillarCard().Begin())
            {
                @using (Html.BlockBuilder().AsTopMargin().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-shield-lock text-success me-1").Begin()) { }
                    @Html.TitleBuilder().SetTitle("Security Helpers", TitleLevel.Five).AsCompact().Render()
                }
                @using (Html.PB_P().AsSmallMuted().Begin())
                {
                    @:Captcha, hash and session guard features provide reusable web safety building blocks.
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsPillarCard().Begin())
            {
                @using (Html.BlockBuilder().AsTopMargin().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-gear-wide-connected text-warning me-1").Begin()) { }
                    @Html.TitleBuilder().SetTitle("Web Configuration", TitleLevel.Five).AsCompact().Render()
                }
                @using (Html.PB_P().AsSmallMuted().Begin())
                {
                    @:Startup helpers make web-specific package setup explicit and consistent.
                }
            }
        }
    }
}

@* ── Philosophy ── *@
@using (Html.BlockBuilder().AsSectionContent().Begin())
{
    @using (Html.FlexBlockBuilder().WithGap(Old_Gap.Gap3).SetAlignItemsStretch().Begin())
    {
        @using (Html.BlockBuilder().AsInfoCallout().SetStyle("margin", "0").SetStyle("flex", "2").Begin())
        {
            @using (Html.FlexBlockBuilder().Begin())
            {
                @using (Html.BlockBuilder().AsCalloutIcon().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-lightbulb-fill fs-2 text-info").Begin()) { }
                }
                @using (Html.BlockBuilder().Begin())
                {
                    @Html.TitleBuilder().SetTitle("Role in the stack", TitleLevel.Four).AsAlertHeading().Render()
                    @using (Html.PB_P().AsNoMargin().Begin())
                    {
                        @:DMBServerWebHelper belongs between the generic server layer and the visual rendering layer. It prepares ASP.NET Core web concerns so page and component builders can focus on rendering.
                    }
                }
            }
        }
        @using (Html.BlockBuilder().AsSidebarCard().SetStyle("flex", "1").Begin())
        {
            @using (Html.BlockBuilder().AsPaddedBlock().SetStyle("height", "100%").Begin())
            {
                @using (Html.FlexBlockBuilder().SetFlexColumn().SetAlignItemsStart().SetJustifyContentCenter().SetStyle("height", "100%").Begin())
                {
                    @Html.TitleBuilder().SetTitle("Next Step", TitleLevel.Five).Render()
                    @using (Html.PB_P().AsSmallMuted().Begin())
                    {
                        @:Learn how to register web helpers in your project.
                    }
                    @Html.Button(ActionItemFactory.AspRoute("ServerWebHelper", "GettingStarted").SetTitle("Getting Started").SetIcon(IconStruct.Bootstrap("bi-play-fill")).SetVariant(VariantStyle.Primary)).Render()
                }
            }
        }
    }
}
